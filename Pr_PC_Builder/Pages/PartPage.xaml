<Page x:Class="Pr_PC_Builder.Pages.PartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr_PC_Builder.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PartPage"
      Background="Salmon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <ListBox Grid.Column="1" x:Name="TypeList" d:ItemsSource="{d:SampleData ItemCount=5}" MouseDoubleClick="TypeList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{Binding image}" Width="70"></Image>
                        <TextBlock Text="{Binding preview}" Margin="15, 0, 0, 0"/>

                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

            <Button x:Name="BackBtn" Width="100" Height="75" Content="Назад" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="15" Click="BackBtn_Click"/>
    </Grid>
</Page>
