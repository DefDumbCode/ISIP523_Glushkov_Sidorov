<Page x:Class="Pr_PC_Builder.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr_PC_Builder.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage"
      Background="Salmon">

    <Grid>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ListBox x:Name="UnitList" Grid.Column="0" Margin="10" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" >
                        <Image Source="{Binding image}" Width="70"></Image>
                        <StackPanel>
                            <TextBlock Text="{Binding name}" Margin="15, 0, 15, 0"></TextBlock>
                            <TextBlock Text="{Binding }" Margin="15, 0, 15, 0" ></TextBlock>
                        </StackPanel>
                        <TextBlock Text="{Binding price, StringFormat=Цена: {0}}" Margin="15, 0, 0, 0"/>
                        <Button x:Name="Butt1" Height="50" Width="80" Margin="15" Content="Добавить" Click="Butt1_Click"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


    </Grid>
</Page>
