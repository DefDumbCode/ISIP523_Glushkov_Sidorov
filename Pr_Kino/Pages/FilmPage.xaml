<Page x:Class="Pr_Kino.FilmPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr_Kino"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FilmPage"
      Background="Beige">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel>
            <Image Source="{Binding ImagePath}" Width="250" Height="300"></Image>
            <TextBlock Text="{Binding Name}" Margin="20,0,0,0"/>
            <TextBlock Text="{Binding Rating, StringFormat=Оценка: {0}}" Margin="20,0,0,0"/>
            <TextBlock Text="{Binding Release_Date, StringFormat=Релиз: {0}}" Margin="20,0,0,0"/>
            <TextBlock Text="Жанры: " Margin="20,0,0,0" x:Name="GenreTB"/>
            <TextBlock Text="{Binding Segregation.AgeRate, StringFormat=Рейтинг: }" Margin="20,0,0,0"/>
            <TextBlock Text="{Binding Description}" Margin="20, 0, 0, 0"/>
        </StackPanel>
        <Button x:Name="BackBtn" Height="50" Width="100" 
        VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="5" Content="Назад" FontSize="20" Click="BackBtn_Click"/>


        <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                 x:Name="SeansList" Grid.Row="1" Grid.Column="1" MouseDoubleClick="SeansList_MouseDoubleClick_1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Room.Name}"/>
                        <TextBlock Text="{Binding Room.Room_Rating.RoomQuality}"/>
                        <TextBlock Text="{Binding Date}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Stretch">
                    </WrapPanel>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Page>
