<Page x:Class="Pr_Kino.MainePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr_Kino"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainePage"
      Background="Beige">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="5*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="2.5*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Column="1">
            <TextBox x:Name="SearchBar" Height="30" Width="400" TextChanged="SearchBar_TextChanged"/>
        </StackPanel>

        <StackPanel Orientation="Vertical" Grid.Column="0">
            <Label Content="Сортировка:" HorizontalAlignment="Center"/>
            <ComboBox x:Name="FilterBox" Grid.Row="0" Grid.Column="0" Margin="15" SelectionChanged="FilterBox_SelectionChanged"/>
        </StackPanel>
        <Button x:Name="UserButt" Grid.Row="0" Grid.Column="2" Margin="20" Content="Войти в аккаунт" Click="UserButt_Click"/>

        <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled" x:Name="FilmList"
                 MouseDoubleClick="FilmList_MouseDoubleClick" Grid.Row="1" Grid.Column="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <Image Source="{Binding ImagePath}" Width="150" Height="250"></Image>
                        <TextBlock Text="{Binding Name}"/>
                        <TextBlock Text="{Binding Rating, StringFormat=Оценка: {0}}"/>
                        <TextBlock Text="{Binding Release_Date, StringFormat=Релиз: {0}}"/>
                        <TextBlock Text="{Binding Segregation.AgeRate, StringFormat=Рейтинг: }"/>

                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Stretch">
                    </WrapPanel>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Page>
