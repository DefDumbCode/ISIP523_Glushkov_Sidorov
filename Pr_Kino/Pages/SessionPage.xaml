<Page x:Class="Pr_Kino.Pages.SessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr_Kino.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SessionPage"
      Background="AliceBlue">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3.5*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="SeatList" Width="550" Height="320" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MouseDoubleClick="SeatList_MouseDoubleClick">
        <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="Gray" Width="75" Height="75"> 
                        <TextBlock Text="{Binding Seat.Name}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                    </Border>
                </DataTemplate>
        </ListBox.ItemTemplate>
        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel HorizontalAlignment="Center">
                </WrapPanel>
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        </ListBox>
            <Button x:Name="BackBTN" Grid.Row="1" Width="100" Height="50" HorizontalAlignment="Left" Margin="15" Content="Назад" FontSize="25" Click="BackBTN_Click"/>
    </Grid>
</Page>
