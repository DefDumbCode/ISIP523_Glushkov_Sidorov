<Page x:Class="Pr_Kino.LogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr_Kino"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LogPage">

    <Grid Background="Beige">
        <StackPanel HorizontalAlignment="Center">
            <Label Width="250" Content="Вход в аккаунт" FontSize="35" Margin="15" HorizontalContentAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label FontSize="25" Content="Логин:" Margin="10"/>
                <TextBox x:Name="LogName" Width="250" Height="30"/>    
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label FontSize="25" Content="Пароль:" Margin="10"/>
                <TextBox x:Name="PassName" Width="250" Height="30"/>
            </StackPanel>
            <Button x:Name="EnterButt" Height="45" Width="100" Content="Войти" Margin="0, 20, 0, 0"/>
            <Label Content="Нет аккаунта?" FontSize="20" HorizontalAlignment="Center" Margin="0, 0,0,0"/>
            <Button x:Name="RegButt" Height="45" Width="100" Content="Регистрация" Margin="0, 15, 0, 0" Click="RegButt_Click"/>

            
        </StackPanel>
    </Grid>
</Page>
