<Page x:Class="Prr13.OrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Prr13"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrderPage"
      Background="Gray">

    <Grid>
        <StackPanel HorizontalAlignment="Right"> 
            <Label Content="Конечный заказ: "  FontSize="20" Margin="15, 5, 5, 5" x:Name="Final"></Label>
            <TextBox VerticalAlignment="Center" Margin="5" Width="200" Height="250" x:Name="TotalTB"></TextBox>
            <Label Content="" FontSize="20" Margin="15, 5, 5, 5" x:Name="Cost"></Label>
        </StackPanel>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Label Content="ФИО:" Margin="25" FontSize="20"/>
                <TextBox x:Name="FIOtb" Width="190" Height="25" Margin="15" TextChanged="ADREStb_TextChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Эл. Почта:" Margin="25" FontSize="20"/>
                <TextBox x:Name="EMAILtb" Width="190" Height="25" Margin="25" TextChanged="ADREStb_TextChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Адрес:" Margin="25" FontSize="20"/>
                <TextBox x:Name="ADREStb" Width="190" Height="25" Margin="15" TextChanged="ADREStb_TextChanged"/>
            </StackPanel>
       </StackPanel>
        <Button x:Name="Butt5" Height="45" Width="100" Margin="15" Content="Назад" VerticalAlignment="Bottom" HorizontalAlignment="Left" Click="Butt5_Click"/>
        <Button x:Name="Butt6" Height="45" Width="100" Margin="15" Content="Оформить" VerticalAlignment="Bottom" HorizontalAlignment="Center" Click="Butt6_Click" IsEnabled="False"/>
    </Grid>
</Page>
