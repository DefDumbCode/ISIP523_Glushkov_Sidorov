<Page x:Class="Prr13.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Prr13"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CartPage"
      Background="Gray">

    <Grid>
        <StackPanel>
            <Label Content="Коризна покупок:" FontSize="20" HorizontalAlignment="Center"/>
            <TextBox x:Name="CartList" Height="250" Width="350" VerticalAlignment="Top"/>

        </StackPanel>
        <Button x:Name="Butt3" Height="45" Width="100" Margin="15" Content="Далее" VerticalAlignment="Bottom" HorizontalAlignment="Right" Click="Butt3_Click"/>
        <Button x:Name="Butt4" Height="45" Width="100" Margin="15" Content="Назад" VerticalAlignment="Bottom" HorizontalAlignment="Left" Click="Butt4_Click"/>
    </Grid>
</Page>
